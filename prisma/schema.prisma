generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Lawyer {
  id          Int      @id @default(autoincrement())
  uniqueId    String   @unique @default(uuid())
  name        String
  title       String
  bio         String?
  image       String?
  email       String?
  phone       String?
  education   String?
  expertise   String?
  languages   String?
  socialLinks String?
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Article {
  id           Int      @id @default(autoincrement())
  uniqueId     String   @unique @default(uuid())
  title        String
  slug         String   @unique
  content      String
  excerpt      String?
  image        String?
  readingTime  String?
  keyTakeaways String?
  authorName   String?
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  category     String   @default("article")
  eventDate    DateTime?
  location     String?
  jobType      String?
}

model PracticeArea {
  id          Int      @id @default(autoincrement())
  uniqueId    String   @unique @default(uuid())
  title       String
  slug        String   @unique
  description String
  tags        String?
  icon        String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Client {
  id        Int      @id @default(autoincrement())
  uniqueId  String   @unique @default(uuid())
  name      String
  logo      String?
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Media {
  id        Int       @id @default(autoincrement())
  uniqueId  String    @unique @default(uuid())
  title     String
  url       String
  publisher String?
  date      DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Setting {
  id        Int      @id @default(autoincrement())
  uniqueId  String   @unique @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  uniqueId  String   @unique @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
